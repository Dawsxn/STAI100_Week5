# Copy to .env and fill in. NEVER commit your real .env (it is git-ignored).

# Provider: "gemini" (real) or "mock" (offline, no key)
LLM_PROVIDER=gemini

# Free dedicated key from https://aistudio.google.com (no credit card, no charge)
GEMINI_API_KEY=your-free-gemini-key-here

GEN_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001

# Free tier => estimated_cost_usd logs 0.0. Set to false to compute real $ from the price table.
FREE_TIER=true
